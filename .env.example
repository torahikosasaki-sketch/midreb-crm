# Supabase (Postgres)
# Supabase ダッシュボード > Project Settings > Database > Connection string から取得
#
# DATABASE_URL: アプリ実行時用。Connection pooling（Transaction, port 6543）+ pgbouncer=true
# DIRECT_URL  : マイグレーション用。Direct connection（port 5432）
#
# 例:
# DATABASE_URL="postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.<project-ref>:<PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres"

DATABASE_URL=""
DIRECT_URL=""
