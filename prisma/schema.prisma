// midreb 営業CRM スキーマ
// DB: Supabase(Postgres)。enum / 配列はプロバイダ非依存にするため String で保持し、
// アプリ層(src/lib/enums.ts)で値を制約する。
// DATABASE_URL = Supabase 接続プーラー(6543, pgbouncer=true) — アプリ実行時用
// DIRECT_URL   = Supabase 直結(5432)                        — マイグレーション用

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

/// 顧客企業（取引先・見込み客のマスター）
model Account {
  id               String      @id @default(cuid())
  name             String // 企業名
  businessTypes    String[]    @default([]) // 事業タグ（複数）
  logoUrl          String? // 顧客ロゴ（データURI）
  industry         String? // 業種
  region           String? // 国内/海外
  owner            String? // 担当者
  status           String? // ステータス
  contactName      String? // 連絡先(担当者名)
  email            String? // メール
  phone            String? // 電話
  firstContactDate DateTime? // 初回接触日（リードが「アプローチ中」等に初めて進んだ日。自動設定）
  contractDate     DateTime? // 契約締結日（商談が受注フェーズに初めて到達した日。自動設定）
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  deals            Deal[]
  leads            Lead[]
}

/// リード（商談化前の見込み。企業必須）
model Lead {
  id             String     @id @default(cuid())
  account        Account    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  accountId      String // 企業（必須）
  source         String? // リードソース／流入経路
  status         String     @default("新規") // 新規/アプローチ中/商談化/長期追客/営業対象外
  owner          String? // 担当（インサイドセールス）
  nextActionDate DateTime? // 次回アクション日
  memo           String?
  deal           Deal? // 商談化で生成される商談（1:1）
  activities     Activity[]
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([accountId])
  @@index([status])
}

/// 商談（営業案件・主役エンティティ）
model Deal {
  id                 String       @id @default(cuid())
  account            Account?     @relation(fields: [accountId], references: [id], onDelete: SetNull)
  accountId          String?
  businessType       String // 事業区分
  phase              String       @default("初回商談予定") // フェーズ
  customerized       Boolean      @default(false) // 顧客化済み（受注で顧客ページに反映）
  lead               Lead?        @relation(fields: [leadId], references: [id], onDelete: SetNull)
  leadId             String?      @unique // 生成元リード（nullは企業から直接作成）
  probability        Float        @default(0) // 確度 (0-1)
  inflowChannel      String? // 流入経路
  agencyName         String? // 代理店名
  owner              String? // 担当者
  expectedCloseDate  DateTime? // 受注予定日
  nextActionDate     DateTime? // 次回アクション日（社内運用: リマインド用）
  chatTool           String? // チャットツール
  channelName        String? // チャンネル名
  contractStatus     String? // 契約ステータス
  contractType       String? // 契約種別
  contractLink       String? // 契約書リンク
  memo               String? // メモ
  position           Int          @default(0) // カンバン内の並び順
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  activities         Activity[]
  lineItems          DealLineItem[]

  @@index([phase])
  @@index([businessType])
  @@index([accountId])
}

/// 案件明細（サービス単位の課金。月次定額/単発、契約期間・解約を保持）
model DealLineItem {
  id            String    @id @default(cuid())
  deal          Deal      @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId        String
  name          String // サービス名/品目
  billingType   String    @default("単発") // 月次定額 / 単発
  amount        Int       @default(0) // 単価（月次定額=月額 / 単発=総額）
  quantity      Int       @default(1) // 数量
  contractStart DateTime? // 契約開始日（月次定額）
  contractEnd   DateTime? // 更新予定日（月次定額）
  status        String    @default("契約中") // 契約中 / 解約（月次定額）
  churnDate     DateTime? // 解約日
  position      Int       @default(0) // 行の並び順
  createdAt     DateTime  @default(now())

  @@index([dealId])
}

/// 活動ログ（架電・MTG・提案送付などの行動履歴）。商談 or リードに紐づく
model Activity {
  id         String   @id @default(cuid())
  deal       Deal?    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  dealId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId     String?
  type       String // 種別 (架電/MTG/提案送付/その他)
  content    String? // 内容
  occurredAt DateTime @default(now()) // 発生日時
  owner      String? // 担当者
  createdAt  DateTime @default(now())

  @@index([dealId])
  @@index([leadId])
}

/// 販売単位（ブランド×商品）。進捗管理の主軸マスター
model SalesUnit {
  id            String           @id @default(cuid())
  brand         String // ブランド
  productSku    String? // 商品名/SKU
  store         String? // 利用ストア
  weeklyTarget  Int? // 週次目標（販売数）
  dailyAdBudget Int? // 日予算（広告費の消化率算出の既定値）
  status        String           @default("稼働中") // 稼働中 / 終了
  memo          String?
  createdAt     DateTime         @default(now())
  weeks         WeeklyProgress[]
  dailyReports  DailyReport[]

  @@index([status])
}

/// 週次進捗（販売単位 × 週の動画/ライブ実績）。目標差分は算出（目標 − 動画販売 − ライブ販売）
model WeeklyProgress {
  id             String    @id @default(cuid())
  salesUnit      SalesUnit @relation(fields: [salesUnitId], references: [id], onDelete: Cascade)
  salesUnitId    String
  weekStart      DateTime // 週開始日
  targetCount    Int? // 週次目標（未指定なら販売単位のweeklyTarget）
  videoPosts     Int? // 動画投稿数
  videoPosters   Int? // 動画投稿人数
  videoSales     Int? // 動画経由販売数
  videoGmv       Int? // 動画売上（GMV）
  liveCount      Int? // ライブ実施回数
  livePresenters Int? // ライブ配信人数
  liveSales      Int? // ライブ配信経由販売数
  liveGmv        Int? // ライブ売上（GMV）
  activityNote   String? // 活動記録
  createdAt      DateTime  @default(now())

  @@unique([salesUnitId, weekStart])
  @@index([salesUnitId])
}

/// 日次レポート（販売単位 × 日付の実績）。レポート機能「日次進捗報告」の元データ
model DailyReport {
  id             String    @id @default(cuid())
  salesUnit      SalesUnit @relation(fields: [salesUnitId], references: [id], onDelete: Cascade)
  salesUnitId    String
  reportDate     DateTime // 対象日（00:00に正規化して保存）
  videoPosts     Int? // 動画投稿数
  liveCount      Int? // ライブ実施回数
  adSpend        Int? // 広告費
  adGmv          Int? // 売上（GMV）※広告経由
  orderCount     Int? // 注文数
  dailyBudget    Int? // 日予算（未指定ならSalesUnit.dailyAdBudgetを使用）
  shippingQty    Int? // 配送依頼: 売上個数
  shippingAmount Int? // 配送依頼: 売上金額
  memo           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([salesUnitId, reportDate])
  @@index([salesUnitId])
  @@index([reportDate])
}

/// 目標 vs 実績
model Target {
  id               String  @id @default(cuid())
  label            String // フェーズ/期間
  monthlyGmvTarget Int? // 月間GMV目標
  sellerTarget     Int? // セラー数目標
  creatorTarget    Int? // クリエイター数目標
  productionTarget Int? // 制作本数目標
}

/// 従業員（担当者マスタ）。owner系の選択肢
model Employee {
  id        String   @id @default(cuid())
  name      String // 氏名
  email     String? // メール
  role      String? // 役割（例: 営業 / 運用 / PM）
  active    Boolean  @default(true) // 稼働中
  createdAt DateTime @default(now())

  @@index([active])
}
